# Anthropic API key — required for the Agent SDK query() loop.
# Without it, the agent falls back to a deterministic heuristic recommendation
# engine built on yfinance data so the rest of the stack still runs end-to-end.
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity Sonar API key — OPTIONAL. Powers the perplexity_ask MCP web-search
# tool. If absent the agent skips web search and logs a warning.
PERPLEXITY_API_KEY=pplx-...

# OpenObserve root credentials (used for UI login and OTLP Basic auth).
ZO_ROOT_USER_EMAIL=admin@poc.local
# OpenObserve enforces password complexity: 8-128 chars with at least one
# lowercase, uppercase, digit, and special character.
ZO_ROOT_USER_PASSWORD=Changeme123!

# Identifiers stamped onto emulated Compliance / Analytics records.
POC_ORG_ID=poc-org-00000000-0000-0000-0000-000000000001
POC_WORKSPACE_ID=wrkspc-00000000-0000-0000-0000-000000000001

# Drop-in replacement path: point these at https://api.anthropic.com with a real
# Admin key to swap the emulators for the real Anthropic enterprise feeds.
COMPLIANCE_API_BASE=http://compliance-api:8001
ANALYTICS_API_BASE=http://analytics-api:8002
